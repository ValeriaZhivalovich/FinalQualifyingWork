# Database
DATABASE_URL=sqlite:///news_analyzer.db

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral:7b

# Telegram (optional — all 3 required to enable)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=

# VK (optional)
VK_ACCESS_TOKEN=

# Twitter/X (optional — all 3 required to enable)
TWITTER_USERNAME=
TWITTER_PASSWORD=
TWITTER_EMAIL=

# Reddit (optional — all 3 required to enable)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=

# Scheduler
FETCH_INTERVAL_MINUTES=30

# UI
UI_THEME=light
